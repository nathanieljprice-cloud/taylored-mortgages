# Required
ANTHROPIC_API_KEY=your_anthropic_key_here
SECRET_KEY=replace_with_a_long_random_string

# Optional: set to 1 for local development
FLASK_DEBUG=1

# Optional: path for clients/, builds/ directories (defaults to app directory)
STORAGE_DIR=.

# Standalone deployments only (mortgagesite-builder repo):
# Absolute path to the cloned taylored-mortgages site template.
# Not needed when running from within taylored-mortgages/platform/ itself.
TEMPLATE_ROOT=/absolute/path/to/taylored-mortgages

# Support email shown in the blog-post-guide.html client handoff doc
SUPPORT_EMAIL=support@yourdomain.com

# Optional: GitHub — needed to create private client repos
# Token needs: repo scope (create + push)
GITHUB_TOKEN=your_github_personal_access_token
GITHUB_ORG=your_github_org_name   # leave blank to use your personal account

# Optional: Netlify — needed to deploy live sites
# Token: Settings > Applications > Personal access tokens
NETLIFY_TOKEN=your_netlify_personal_access_token
